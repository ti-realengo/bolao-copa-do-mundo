# App
APP_URL=http://localhost:3000
DEFAULT_LOCALE=pt-BR
TIMEZONE=America/Sao_Paulo

# Auth — sessão usa esse secret pra assinar cookies. Mude para um valor aleatório.
SESSION_SECRET=change-me-to-a-random-32-byte-hex

# Local DB (dev)
DATABASE_URL=./data/bolao.db

# Football-Data.org — API key pra puxar resultados (necessário para sync)
FOOTBALL_DATA_API_KEY=

# Cron — bearer token usado pra autenticar invocações dos endpoints /api/cron/*
CRON_SECRET=

# Resend (OPCIONAL — sem isso, emails de notificação são logados no console em dev)
RESEND_API_KEY=
RESEND_FROM_EMAIL=bolao@empresa.com.br
