{
  "name": "bolao-copa-do-mundo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:scheduler": "tsx --env-file=.env scripts/dev-scheduler.ts",
    "build": "opennextjs-cloudflare build && node scripts/cf-postbuild-patch.mjs",
    "next:build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file=.env scripts/migrate.ts",
    "fd:sync": "tsx --env-file=.env scripts/sync-football-data.ts",
    "cf:bootstrap": "tsx scripts/cf-bootstrap.ts",
    "cf:build": "pnpm build",
    "cf:deploy": "pnpm build && opennextjs-cloudflare deploy",
    "cf:migrate": "wrangler d1 migrations apply bolao-prod --remote",
    "cf:dev": "wrangler dev"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.4",
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "better-sqlite3": "^11.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.36.4",
    "lucide-react": "^0.460.0",
    "marked": "^18.0.2",
    "nanoid": "^5.0.9",
    "next": "^15.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^4.0.1",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.28.1",
    "postcss": "^8.4.49",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wrangler": "^4.86.0"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp"
    ]
  }
}
